# Bazarr
BAZARR_URL=http://localhost:6767
BAZARR_API_KEY=your_bazarr_api_key_here

# Sonarr
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key_here

# Radarr
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here

# ── Fase 3: Acceso a archivos físicos ───────────────────────
# Modo: network (Windows via SMB) | local (directo en el servidor)
RUN_MODE=network

# Rutas de red (Windows - credenciales en Administrador de Credenciales)
SERIES_NETWORK=//192.168.1.52/Series
MOVIES_NETWORK=//192.168.1.52/Movies
OUTPUT_NETWORK=C:/dev_backup/Subtitulos

# Rutas locales (cuando el script corra en el servidor)
SERIES_LOCAL=/series
MOVIES_LOCAL=/movies
OUTPUT_LOCAL=/backup/subtitulos
